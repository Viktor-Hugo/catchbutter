{
  "name": "catchbutter",
  "version": "1.0.0",
  "description": "Local-first multiplayer drawing game prototype",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client run dev -- --host 0.0.0.0\"",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
